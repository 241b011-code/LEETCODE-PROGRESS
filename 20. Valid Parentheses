class Solution {
public:
   bool isValid(string s) {
    stack<char> st;
    unordered_map<char, char> mp = {
        {')', '('},
        {'}', '{'},
        {']', '['}
    };

    for (char c : s) {
        // If it's an opening bracket, push to stack
        if (c == '(' || c == '{' || c == '[') {
            st.push(c);
        } 
        // If it's a closing bracket
        else {
            if (st.empty() || st.top() != mp[c]) {
                return false;
            }
            st.pop();
        }
    }

    return st.empty();
}
};
