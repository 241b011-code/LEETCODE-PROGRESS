class Solution {
public:
    int firstMissingPositive(vector<int>& nums) {
                sort(nums.begin(),nums.end());
            int num=1;
            for(int i=0;i<nums.size();i++){
                  if(nums[i]>=1){
                      if(nums[i]==num){
                            while(i<nums.size()-1 && nums[i]==nums[i+1]){
                                 i++;
                            }
                           num+=1; 
                      } 
                      else{
                          break;
                      }
                  }
            }
            return num;

    }
};
