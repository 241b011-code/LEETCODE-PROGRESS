class Solution {
public:
    int threeSumClosest(vector<int>& nums, int target) {
                   int n=nums.size();
                   int ans=1000000;
                  //  sort(nums.begin(),nums.end());
                  for(int i=0;i<n-2;i++){
                        for(int j=i+1;j<n-1;j++){
                                for(int k=j+1;k<n;k++){
                                        int sum=nums[i]+nums[j]+nums[k];
                                        int t=abs(target-sum);
                                        int p=abs(target-ans);
                                        if(p>t){
                                             ans=sum; 
                                        }
                                      
                                }
                        }
                  }
      return ans;
    }
};
