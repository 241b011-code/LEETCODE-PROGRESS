/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
    ListNode* mergeTwoLists(ListNode* list1, ListNode* list2) {
              vector<int>nums;
              while(list1!=NULL){
                   int p=list1->val;
                   cout<<p<<" ";
                   list1=list1->next;
                   nums.push_back(p);
              }
              while(list2!=NULL){
                   int v=list2->val;
                   list2=list2->next;
                   nums.push_back(v);
              }
              sort(nums.begin(),nums.end());
              ListNode* head=new ListNode(0);
              ListNode*ans=head;
              for(int a:nums){
                   head->next=new ListNode(a);
                   head=head->next;
                //  cout<<a<<" ";
              }
              return ans->next;
    }
};
