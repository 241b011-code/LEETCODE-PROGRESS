/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
    ListNode* removeNthFromEnd(ListNode* head, int n) {
           ListNode* temp1=head;
           ListNode* temp2=head;
           ListNode*temp=head;
           int c=0;
           while(temp!=NULL){
                 c++;
                 temp=temp->next;
           }
           if(n==c){
              head=head->next;
              return head;
           }

           if(head->next==NULL){
                head=NULL;
                return head;
           }
           int i=0;
           while(i<n){
                    i++;
                    temp1=temp1->next;
           }
           while(temp1!=NULL && temp1->next!=NULL){
                 temp1=temp1->next;
                 temp2=temp2->next;
           }
           temp2->next=temp2->next->next;
           return head;
    }
};
