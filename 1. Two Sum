class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) { 
        vector<int>tsum;
             int s=nums.size();
            
             for(int i=0;i<s;i++){
                        //int sum=0;
                        for(int j=i+1;j<s;j++){
                                    if(target==(nums[i]+nums[j])){
                                        tsum.push_back(i);
                                        tsum.push_back(j);
                                        return tsum;
                                    } 

                        }

             }

    
    
    return tsum;
     }
        

};
