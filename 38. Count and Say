class Solution {
public:
   string convert(string nums){
           int n=nums.length();
           string ans;
           for(int i=0;i<n;i++){
                  char num=nums[i];
                  int c=0;
                  while(num==nums[i]){
                      c++;
                      i++;
                  }
                  string temp=to_string(c);
                  for(char a:temp){
                        ans+=a;
                  }
                  ans+=num;
                  i--;
           }
           return ans;
   }
    string countAndSay(int n) {
          string ans="1";
          while(n>1){
              n--;
              ans=convert(ans);
         }
         return ans;
    }
};
