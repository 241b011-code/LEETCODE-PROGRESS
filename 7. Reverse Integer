class Solution {
public:
    int reverse(int x) {
        long y=0;
        int ch=1;
    if(x>INT_MAX){  
        return 0;  
        }  
        
    else{
        if(x<0){
            if((x+1)*-1>=INT_MAX)
                return 0;
            x=x*-1;
            ch=-1;
        }
     while(x!=0){
         int t=x%10;
         if(y*10>INT_MAX){
            return 0;
         }
         y=y*10+t;
         x=x/10;
    }

    } 
    return y*ch;  
    }
      

};
