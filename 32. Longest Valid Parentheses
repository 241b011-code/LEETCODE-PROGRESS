class Solution {
public:
    int longestValidParentheses(string s) {
          stack<int> st;
    int maxLength = 0;
    int lastInvalid = -1; // Tracks the last invalid ')'

    for (int i = 0; i < s.length(); i++) {
        if (s[i] == '(') {
            st.push(i); // Store the index of '('
        } else {
            if (!st.empty()) {
                st.pop();
                int validLength = st.empty() ? i - lastInvalid : i - st.top();
                maxLength = max(maxLength, validLength);
            } else {
                lastInvalid = i; // Mark last invalid ')'
            }
        }
    }
    return maxLength;
}
};
