class Solution {
public:
    int jump(vector<int>& nums) {
             int curr=0;
             int ans=0;
             int n=nums.size();
             vector<int>dp(n,INT_MAX);
             dp[0]=0;
             for(int i=0;i<n;i++){
                   int end=nums[i]+i;
                   int st=i;
                   int jump=dp[i]+1;
                   while(st<n && st<=end){
                          dp[st]=min(dp[st],jump);
                          st++;
                   }
             }
            
             return dp[n-1];
    
    }
};
