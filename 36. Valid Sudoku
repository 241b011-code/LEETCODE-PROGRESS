class Solution {
public:
    bool isvalid(vector<vector<char>>& board,int r,int c){
             char ch=board[r][c];
             int count=0;
             for(int i=0;i<9;i++){
                   if(board[i][c]==ch){
                            count++;
                   }
             }
             if(count>1) return false;
             count=0;
             for(int j=0;j<9;j++){
                   if(board[r][j]==ch){
                            count++;
                   }
             }
             if(count>1) return false;
             count=0;
             int r1=(r/3)*3;
             int c1=(c/3)*3;
              for(int i=r1;i<r1+3;i++){
                 for(int j=c1;j<c1+3;j++){
                              if(board[i][j]==ch){
                            count++;
                   }
                 }
              }
             if(count>1) return false;
             return true;
    }


    bool isValidSudoku(vector<vector<char>>& board) {
             for(int i=0;i<9;i++){
                 for(int j=0;j<9;j++){
                       if(board[i][j]!='.' && !isvalid(board,i,j)){
                                 return false;
                       }
                 }
             }
             return true;
    }
};
