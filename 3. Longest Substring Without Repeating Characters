class Solution {
public:
  int lengthOfLongestSubstring(string s) {
    vector<int> index(128, -1); // ASCII size
    int ans = 0, i = 0;

    for (int j = 0; j < s.length(); ++j) {
        if (index[s[j]] >= i) {
            i = index[s[j]] + 1;
        }
        index[s[j]] = j;
        ans = max(ans, j - i + 1);
    }

    return ans;
}

};
