class Solution {
public:
     
    int myAtoi(string s) {
         long double ans=0;
         int count=0;
         int sign=0;
         //int num=isnum[s[0]];

         for(int i=0;i<s.length();i++){
            while(s[i]==' ' && count==0){
                i++;
            }
            if((s[i]=='-')&& count==0){
                  sign=1;
                  count=1;
                  continue;
              }
              if((s[i]=='+')&& count==0){
                   count++;
                   continue;
              }

              char num=s[i];
              if(num=='1'){
                count++;
                 ans=ans*10+1;
              }
            else if(num=='2'){
                count++;
                 ans=ans*10+2;
              }
            else if(num=='3'){
                count++;
                 ans=ans*10+3;
              }
            else if(num=='4'){
                count++;
                 ans=ans*10+4;
                 count++;
              }
            else if(num=='5'){
                  count++;
                 ans=ans*10+5;
              }
            else if(num=='6'){
                 count++;
                 ans=ans*10+6;
              }
            else if(num=='7'){
                count++;
                 ans=ans*10+7;
              }
            else if(num=='8'){
                count++;
                 ans=ans*10+8;
              }
            else if(num=='9'){
                count++;
                 ans=ans*10+9;
              }
            else if(num=='0'){
                count++;
                 ans=ans*10+0;
              }
             else{           
                break;
             }
             
         }
          if(sign==1){
          ans=ans*-1;
       }
       if(ans>INT_MAX){
            ans=INT_MAX;
       }
       if(ans<INT_MIN){
            ans=INT_MIN;
       }
         return (int)ans;
    }
};
